<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InternetBankingApp.Controls.LoadingDots">

    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
        <Ellipse x:Name="Dot1" WidthRequest="10" HeightRequest="10" Fill="{StaticResource Emerald}" />
        <Ellipse x:Name="Dot2" WidthRequest="10" HeightRequest="10" Fill="{StaticResource Emerald}" />
        <Ellipse x:Name="Dot3" WidthRequest="10" HeightRequest="10" Fill="{StaticResource Emerald}" />
    </HorizontalStackLayout>

</ContentView>
