<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="InternetBankingApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:InternetBankingApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="InternetBankingApp">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.FlyoutItemIsVisible="False" />

    <FlyoutItem Title="Cuentas" Route="CuentasPage">
        <ShellContent ContentTemplate="{DataTemplate views:CuentasPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Préstamos" Route="PrestamosPage">
        <ShellContent ContentTemplate="{DataTemplate views:PrestamosPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Beneficiarios" Route="BeneficiariosPage">
        <ShellContent ContentTemplate="{DataTemplate views:BeneficiariosPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Movimientos" Route="MovimientosPage">
        <ShellContent ContentTemplate="{DataTemplate views:MovimientosPage}" />
    </FlyoutItem>

    <MenuItem Text="Cerrar sesión" Clicked="OnCerrarSesionClicked" />

</Shell>
